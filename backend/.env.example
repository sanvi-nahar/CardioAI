# ==========================================
# CardioAI Backend Environment Variables Template
# ==========================================

# Current application environment (development / production)
NODE_ENV=development

# Server port configuration
PORT=5000

# MongoDB connection string
# For production (MongoDB Atlas): mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/patient-monitor?retryWrites=true&w=majority
# For local development: mongodb://127.0.0.1:27017/patient-monitor
MONGO_URI=mongodb://127.0.0.1:27017/patient-monitor

# Secret key used for signing JWT tokens (use a strong random value in production)
JWT_SECRET=SanviSuperSecretKey2026

# Allowed Frontend Client URL(s) for CORS and Socket.IO matching.
# Support multiple comma-separated URLs (e.g. http://localhost:5173,https://cardio-ai.vercel.app)
FRONTEND_URL=http://localhost:5173

# Optional: Initial Admin User configuration (Used by create_admin.js)
ADMIN_EMAIL=admin@hospital.com
ADMIN_PASSWORD=pass123
